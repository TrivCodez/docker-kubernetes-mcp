# Docker Configuration
DOCKER_HOST=unix:///var/run/docker.sock
# For Windows: DOCKER_HOST=npipe:////./pipe/docker_engine
# For remote: DOCKER_HOST=tcp://localhost:2375

# Kubernetes Configuration
KUBECONFIG=~/.kube/config
# KUBE_CONTEXT=docker-desktop  # Optional: specify context
# KUBE_NAMESPACE=default       # Optional: default namespace

# MCP Server Configuration
MCP_PORT=3000
LOG_LEVEL=info
# MCP_SERVER_NAME=docker-k8s-mcp

# Optional: Registry Configuration
# DOCKER_REGISTRY=https://index.docker.io/v1/
# DOCKER_REGISTRY_USER=
# DOCKER_REGISTRY_PASS=

# Optional: Kubernetes Cluster Settings
# K8S_API_SERVER=https://localhost:6443
# K8S_TLS_SKIP_VERIFY=false